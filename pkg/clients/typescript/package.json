{
  "name": "@fuzztesting/client",
  "version": "1.0.0",
  "description": "TypeScript client SDK for fuzztesting distributed fuzzing orchestration platform",
  "author": "fuzztesting Team <support@ethpandaops.io>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yuvi9559/FuzzTesting.git",
    "directory": "pkg/clients/typescript"
  },
  "homepage": "https://github.com/Yuvi9559/FuzzTesting",
  "bugs": {
    "url": "https://github.com/Yuvi9559/FuzzTesting/issues"
  },
  "keywords": [
    "fuzzing",
    "security-testing",
    "fuzztesting",
    "typescript",
    "api-client",
    "sse",
    "distributed-system"
  ],
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "module": "./dist/esm/index.js",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "docs": "typedoc src/index.ts"
  },
  "dependencies": {
    "eventsource": "^2.0.2",
    "cross-fetch": "^4.0.0"
  },
  "devDependencies": {
    "@types/eventsource": "^1.1.15",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^8.53.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typedoc": "^0.25.3",
    "typescript": "^5.2.2"
  },
  "peerDependencies": {
    "typescript": ">=4.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
