-- Description: Add metadata fields to corpus table for enhanced tracking

-- +migrate Up
-- Add new columns to corpus table
ALTER TABLE corpus ADD COLUMN mutation_strategy TEXT;
ALTER TABLE corpus ADD COLUMN parent_id TEXT REFERENCES corpus(id);
ALTER TABLE corpus ADD COLUMN generation INTEGER DEFAULT 0;
ALTER TABLE corpus ADD COLUMN execution_time_ms INTEGER;
ALTER TABLE corpus ADD COLUMN memory_usage_bytes INTEGER;
ALTER TABLE corpus ADD COLUMN tags TEXT; -- JSON array of tags

-- Create index for parent-child relationships
CREATE INDEX idx_corpus_parent_id ON corpus(parent_id);
CREATE INDEX idx_corpus_generation ON corpus(generation);

-- Create corpus_stats table for aggregated statistics
CREATE TABLE IF NOT EXISTS corpus_stats (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    job_id TEXT NOT NULL,
    total_entries INTEGER DEFAULT 0,
    total_size_bytes INTEGER DEFAULT 0,
    avg_execution_time_ms REAL,
    max_coverage REAL,
    unique_paths INTEGER DEFAULT 0,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (job_id) REFERENCES jobs(id) ON DELETE CASCADE,
    UNIQUE(job_id)
);

-- Create trigger to update corpus_stats
CREATE TRIGGER update_corpus_stats_on_insert
AFTER INSERT ON corpus
BEGIN
    INSERT OR REPLACE INTO corpus_stats (job_id, total_entries, total_size_bytes, updated_at)
    SELECT 
        NEW.job_id,
        COUNT(*),
        SUM(size),
        CURRENT_TIMESTAMP
    FROM corpus
    WHERE job_id = NEW.job_id;
END;

-- +migrate Down
-- Drop trigger
DROP TRIGGER IF EXISTS update_corpus_stats_on_insert;

-- Drop corpus_stats table
DROP TABLE IF EXISTS corpus_stats;

-- Drop indices
DROP INDEX IF EXISTS idx_corpus_parent_id;
DROP INDEX IF EXISTS idx_corpus_generation;

-- Remove columns (SQLite doesn't support DROP COLUMN, so we need to recreate the table)
-- This is a simplified version - in production, you'd want to preserve data
CREATE TABLE corpus_new (
    id TEXT PRIMARY KEY,
    job_id TEXT NOT NULL,
    filename TEXT NOT NULL,
    data BLOB NOT NULL,
    size INTEGER NOT NULL,
    hash TEXT NOT NULL,
    coverage_data TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (job_id) REFERENCES jobs(id) ON DELETE CASCADE,
    UNIQUE(job_id, hash)
);

-- Copy data from old table
INSERT INTO corpus_new SELECT 
    id, job_id, filename, data, size, hash, coverage_data, created_at, updated_at
FROM corpus;

-- Replace old table with new
DROP TABLE corpus;
ALTER TABLE corpus_new RENAME TO corpus;

-- Recreate original indices
CREATE INDEX idx_corpus_job_id ON corpus(job_id);
CREATE INDEX idx_corpus_created_at ON corpus(created_at);
CREATE INDEX idx_corpus_size ON corpus(size);