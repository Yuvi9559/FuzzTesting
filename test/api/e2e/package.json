{
  "name": "@fuzztesting/e2e-playwright",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright-based End-to-end tests for fuzztesting API v1 using TypeScript client",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:codegen": "playwright codegen",
    "install:browsers": "playwright install",
    "lint": "eslint **/*.ts",
    "lint:fix": "eslint **/*.ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf test-results playwright-report",
    "setup": "npm run install:browsers && npm run type-check",
    "docker:up": "docker-compose up -d fuzztesting-master fuzztesting-bot",
    "docker:down": "docker-compose down -v",
    "docker:logs": "docker-compose logs -f",
    "e2e": "npm run docker:up && sleep 10 && npm test && npm run docker:down",
    "e2e:dev": "npm run docker:up && npm run test:ui"
  },
  "dependencies": {
    "@fuzztesting/client": "file:../../../pkg/clients/typescript"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^8.53.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}